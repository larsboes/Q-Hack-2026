{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "mcpServers": {
    "obsidian-notes": {
      "type": "local",
      "command": ["node", "mcp-server/index.js"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "npm *": "allow",
      "git commit *": "allow",
      "rm *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    }
  }
}
